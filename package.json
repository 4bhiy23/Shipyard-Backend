{
  "name": "shipyard-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Shipyard — Engineering Operations & Intelligence Platform (Backend Services)",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:gateway": "node --watch apps/api-gateway/src/index.js",
    "dev:sync": "node --watch apps/sync-engine/src/index.js",
    "dev": "npm run dev:gateway & npm run dev:sync",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "echo \"No tests configured yet\" && exit 0"
  },
  "keywords": [
    "engineering-ops",
    "github-integration",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
