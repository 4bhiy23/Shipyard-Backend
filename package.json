{
  "name": "shipyard-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Shipyard — Engineering Operations & Intelligence Platform (Backend Services)",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:gateway": "node --watch apps/api-gateway/src/index.js",
    "dev:sync": "node --watch apps/sync-engine/src/index.js",
    "dev": "npm run dev:gateway & npm run dev:sync",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "echo \"No tests configured yet\" && exit 0"
  },
  "keywords": ["engineering-ops", "github-integration", "developer-tools"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.3.0"
  }
}
